generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id          String    @id @default(uuid()) @db.Uuid
  telegram_id String    @unique
  first_name  String
  second_name String?
  login       String?
  Servers     Servers[]

  @@map("users")
}

model Servers {
  id      String @id @default(uuid()) @db.Uuid
  name    String
  host    String
  user_id String @db.Uuid
  user    Users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Tasks   Task[]

  @@map("servers")
}

model Task {
  name      String
  interval  String
  server_id String  @db.Uuid
  chat_id   String
  id        String  @id @default(uuid()) @db.Uuid
  Server    Servers @relation(fields: [server_id], references: [id], onDelete: Cascade)

  @@map("task")
}
